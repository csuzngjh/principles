{
  "strictness": 2,
  "reviewLanguage": "zh-CN",
  "commentTypes": ["review", "suggestion", "nitpick"],
  "triggerOnUpdates": true,
  "fileChangeLimit": 50,
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/*.min.js",
    "**/package-lock.json",
    "**/coverage/**",
    "**/*.tgz"
  ],
  "summarySection": {
    "included": true,
    "collapsible": true
  },
  "rules": [
    {
      "id": "typescript-types",
      "description": "确保 TypeScript 类型定义完整且准确",
      "severity": "warning"
    },
    {
      "id": "error-handling",
      "description": "检查错误处理是否完善",
      "severity": "error"
    },
    {
      "id": "security-check",
      "description": "检查潜在的安全问题（XSS、注入等）",
      "severity": "error"
    },
    {
      "id": "performance",
      "description": "识别性能问题",
      "severity": "warning"
    },
    {
      "id": "code-style",
      "description": "代码风格和可读性建议",
      "severity": "info"
    }
  ]
}

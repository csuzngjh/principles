    "gemini": {
      "command": "gemini --acp",
      "description": "Gemini CLI with ACP support (全部免费)",
      "models": {
        "gemini-2.5-pro": {
          "description": "Gemini 2.5 Pro — high reasoning capability",
          "pricing": "free",
          "recommendedTimeoutSeconds": 1800,
          "features": ["high-reasoning"],
          "notes": "高推理能力"
        },
        "gemini-2.5-flash": {
          "description": "Gemini 2.5 Flash — fast response",

{
  "$schema": "agent-registry-v1",
  "description": "Registry of available agents and their supported models for AI sprint orchestrator.",
  "lastUpdated": "2026-04-04",

  "agents": {
    "iflow": {
      "command": "iflow --experimental-acp",
      "description": "iFlow CLI with ACP support",
      "version": "0.5.18",
      "models": {
        "glm-5": {
          "description": "GLM-5 model via iflow ACP adapter",
          "recommendedTimeoutSeconds": 1800,
          "features": ["slow", "needs-extra-time"],
          "notes": "Runs significantly slower than other models. Timeout MUST be >= 1800s for review tasks."
        }
      }
    },

    "opencode": {
      "command": "npx -y opencode-ai acp",
      "description": "OpenCode ACP adapter",
      "version": "1.3.13",
      "models": {
        "minimax-cn-coding-plan/MiniMax-M2.7": {
          "description": "MiniMax M2.7 (coding plan, Chinese-optimized)",
          "recommendedTimeoutSeconds": 1200,
          "features": ["fast", "coding-optimized"],
          "notes": "Default model for producer tasks."
        },
        "minimax-cn-coding-plan/MiniMax-M2.5": {
          "description": "MiniMax M2.5 (coding plan)",
          "recommendedTimeoutSeconds": 1200,
          "features": ["fast", "coding-optimized"],
          "notes": "Faster but less capable than M2.7."
        },
        "minimax-cn-coding-plan/MiniMax-M2.7-highspeed": {
          "description": "MiniMax M2.7 highspeed variant",
          "recommendedTimeoutSeconds": 900,
          "features": ["fast", "highspeed"],
          "notes": "Highspeed variant. Use when latency matters."
        }
      }
    },

    "claude": {
      "command": "claude",
      "description": "Claude Code (Anthropic)",
      "version": "2.1.81",
      "models": {
        "GLM-5.1": {
          "description": "GLM-5.1 via Claude Code adapter",
          "recommendedTimeoutSeconds": 1800,
          "features": ["slow"],
          "notes": "Reserved for escalation/global-reviewer role."
        }
      }
    }
  }
}

{
  "_meta": {
    "template_version": "1.0",
    "description": "AI Sprint Orchestrator task template for 5-stage workflow",
    "pr2_integration_points": {
      "EmpathyObserverManager": {
        "trigger_stage": "verify",
        "trigger_condition": "All implement-pass-* stages completed with APPROVE. Producer report requires empathy persistence verification.",
        "input_contract": {
          "worktree_path": "worktreeInfo.worktreePath from sprint state",
          "producer_report": "stages/<stage>/producer.md with EVIDENCE section",
          "git_status": "stages/<stage>/git-status.json"
        },
        "expected_output": "Structured empathy persistence validation: passed/failed per hypothesis, evidence refs, remaining gaps. Written to stages/verify/empathy-check.json.",
        "failure_mode": "If empathy persistence cannot be confirmed, appends blocker to verify decision."
      },
      "DeepReflect": {
        "trigger_stages": ["implement-pass-1", "implement-pass-2"],
        "trigger_condition": "Producer completes and before reviewer phase. Hook into subagent lifecycle for each code change.",
        "lifecycle_hooks": ["subagent_spawned", "subagent_checkpoint", "subagent_ended"],
        "handoff_artifact": {
          "schema": "stages/<stage>/deep-reflect-checkpoint.json",
          "fields": ["session_key", "run_id", "checkpoint_timestamp", "reflect_payload", "persistence_confirmed"]
        },
        "failure_mode": "Non-blocking. Logs warning to timeline. Does not halt stage."
      }
    }
  },
  "id": "<task-id>",
  "title": "<task title>",
  "workspace": "D:/Code/principles",
  "branchWorkspace": "D:/Code/principles-<task-suffix>",
  "branch": "<pr-branch-name>",
  "maxRoundsPerStage": 3,
  "maxRuntimeMinutes": 360,
  "stageTimeoutMinutes": 30,
  "stages": ["investigate", "patch-plan", "implement-pass-1", "implement-pass-2", "verify"],
  "producer": {
    "agent": "opencode",
    "model": "minimax-cn-coding-plan/MiniMax-M2.7",
    "timeoutSeconds": 120
  },
  "reviewerA": {
    "agent": "iflow",
    "model": "glm-5",
    "timeoutSeconds": 900
  },
  "reviewerB": {
    "agent": "iflow",
    "model": "glm-5",
    "timeoutSeconds": 900
  },
  "escalationReviewer": {
    "agent": "claude",
    "model": "GLM-5.1",
    "timeoutSeconds": 900
  },
  "context": [
    "Use PD-only changes; do not modify OpenClaw.",
    "Keep code quality high and avoid unnecessary architectural expansion."
  ],
  "stageGoals": {
    "investigate": [
      "Identify the most likely root cause chain for the issue.",
      "Confirm whether the issue is reproducible and document failure modes."
    ],
    "patch-plan": [
      "Produce a minimal PD-only repair plan.",
      "Define tests, rollback points, and scope boundaries."
    ],
    "implement-pass-1": [
      "Implement the first-pass fix.",
      "Add focused tests and run targeted verification."
    ],
    "implement-pass-2": [
      "Address review findings from implement-pass-1.",
      "Do not re-disperse or expand scope beyond the original fix-plan."
    ],
    "verify": [
      "Verify the fix path with code and test evidence.",
      "Run merge gate to confirm local SHA matches remote.",
      "Call out any remaining runtime assumptions or production gaps."
    ]
  },
  "stageCriteria": {
    "investigate": {
      "requiredApprovals": 2,
      "requiredProducerSections": ["SUMMARY", "EVIDENCE", "CODE_EVIDENCE", "KEY_EVENTS", "HYPOTHESIS_MATRIX", "CHECKS"],
      "requiredReviewerSections": ["VERDICT", "BLOCKERS", "FINDINGS", "CODE_EVIDENCE", "HYPOTHESIS_MATRIX", "NEXT_FOCUS", "CHECKS"],
      "scoringDimensions": ["evidence_quality", "hypothesis_coverage", "root_cause_confidence"],
      "dimensionThreshold": 3,
      "requiredDeliverables": ["root_cause_identified", "reproduction_steps", "failure_mode_analysis"]
    },
    "patch-plan": {
      "requiredApprovals": 2,
      "requiredProducerSections": ["SUMMARY", "CHANGES", "CODE_EVIDENCE", "EVIDENCE", "CHECKS"],
      "requiredReviewerSections": ["VERDICT", "BLOCKERS", "FINDINGS", "CODE_EVIDENCE", "NEXT_FOCUS", "CHECKS"],
      "scoringDimensions": ["plan_completeness", "risk_assessment", "rollback_safety"],
      "dimensionThreshold": 3,
      "requiredDeliverables": ["minimal_fix_plan", "test_outline", "rollback_steps"]
    },
    "implement-pass-1": {
      "requiredApprovals": 2,
      "requiredProducerSections": ["SUMMARY", "CHANGES", "CODE_EVIDENCE", "EVIDENCE", "KEY_EVENTS", "CHECKS"],
      "requiredReviewerSections": ["VERDICT", "BLOCKERS", "FINDINGS", "CODE_EVIDENCE", "NEXT_FOCUS", "CHECKS"],
      "scoringDimensions": ["correctness", "scope_control", "test_coverage", "regression_risk"],
      "dimensionThreshold": 3,
      "requiredDeliverables": ["targeted_fix", "focused_tests", "verification_evidence"]
    },
    "implement-pass-2": {
      "requiredApprovals": 2,
      "requiredProducerSections": ["SUMMARY", "CHANGES", "CODE_EVIDENCE", "EVIDENCE", "KEY_EVENTS", "CHECKS"],
      "requiredReviewerSections": ["VERDICT", "BLOCKERS", "FINDINGS", "CODE_EVIDENCE", "NEXT_FOCUS", "CHECKS"],
      "scoringDimensions": ["correctness", "scope_control", "test_coverage", "regression_risk"],
      "dimensionThreshold": 3,
      "requiredDeliverables": ["review_findings_addressed", "no_scope_creep", "targeted_verification"]
    },
    "verify": {
      "requiredApprovals": 2,
      "requiredProducerSections": ["SUMMARY", "EVIDENCE", "CODE_EVIDENCE", "CHECKS"],
      "requiredReviewerSections": ["VERDICT", "BLOCKERS", "FINDINGS", "CODE_EVIDENCE", "NEXT_FOCUS", "CHECKS"],
      "scoringDimensions": ["verification_thoroughness", "gap_analysis", "production_readiness"],
      "dimensionThreshold": 3,
      "requiredDeliverables": ["verification_report", "remaining_gaps", "deployment_checklist"]
    }
  },
  "stageRoleTimeouts": {
    "investigate": { "producer": 720, "reviewer_a": 600, "reviewer_b": 600 },
    "patch-plan": { "producer": 600, "reviewer_a": 480, "reviewer_b": 480 },
    "implement-pass-1": { "producer": 900, "reviewer_a": 600, "reviewer_b": 600 },
    "implement-pass-2": { "producer": 600, "reviewer_a": 480, "reviewer_b": 480 },
    "verify": { "producer": 720, "reviewer_a": 480, "reviewer_b": 480 }
  },
  "investigateHypotheses": [
    "<define-hypothesis-id-1>",
    "<define-hypothesis-id-2>"
  ]
}

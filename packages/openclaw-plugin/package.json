{
  "name": "principles-disciple",
  "version": "1.5.5",
  "description": "Native OpenClaw plugin for Principles Disciple",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "templates",
    "openclaw.plugin.json"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/csuzngjh/principles.git",
    "directory": "packages/openclaw-plugin"
  },
  "author": "csuzngjh",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/csuzngjh/principles/issues"
  },
  "homepage": "https://github.com/csuzngjh/principles#readme",
  "openclaw": {
    "id": "principles-disciple",
    "name": "Principles Disciple",
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "build:bundle": "node esbuild.config.js",
    "build:production": "tsc && node esbuild.config.js --production",
    "test": "vitest run",
    "postinstall": "node scripts/install-dependencies.cjs"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.10",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.0.0",
    "vitest": "^4.1.0",
    "ws": "^8.18.0"
  },
  "peerDependencies": {
    "openclaw": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.48",
    "micromatch": "^4.0.8"
  }
}
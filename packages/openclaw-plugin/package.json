{
  "name": "principles-disciple",
  "version": "1.10.40",
  "description": "Native OpenClaw plugin for Principles Disciple",
  "type": "module",
  "main": "./dist/bundle.js",
  "exports": {
    ".": "./dist/bundle.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/csuzngjh/principles.git",
    "directory": "packages/openclaw-plugin"
  },
  "author": "csuzngjh",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/csuzngjh/principles/issues"
  },
  "homepage": "https://github.com/csuzngjh/principles#readme",
  "openclaw": {
    "id": "principles-disciple",
    "name": "Principles Disciple",
    "extensions": [
      "./dist/bundle.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "build:web": "node scripts/build-web.mjs",
    "build:bundle": "node esbuild.config.js && node scripts/build-web.mjs",
    "build:production": "node esbuild.config.js --production && node scripts/build-web.mjs --production && node scripts/verify-build.mjs",
    "test": "vitest run",
    "test:unit": "vitest run tests/core tests/service tests/hooks tests/commands tests/utils tests/scripts --exclude tests/commands/evolver.test.ts",
    "test:integration": "vitest run tests/integration/",
    "test:coverage": "vitest run --coverage",
    "test:all": "vitest run",
    "lint": "eslint \"src/**/*.ts\"",
    "bootstrap-rules": "node scripts/bootstrap-rules.mjs",
    "compile-principles": "node scripts/compile-principles.mjs",
    "validate-live-path": "tsx scripts/validate-live-path.ts"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "jsdom": "^29.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.0",
    "ws": "^8.18.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.4"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "dependencies": {
    "@principles/core": "^0.1.0",
    "@sinclair/typebox": "^0.34.48",
    "better-sqlite3": "^12.9.0",
    "commander": "^12.0.0",
    "js-yaml": "^4.1.1",
    "lucide-react": "^1.7.0",
    "micromatch": "^4.0.8",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.4"
  }
}

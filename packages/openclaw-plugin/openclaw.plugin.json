{
  "id": "principles-disciple",
  "name": "Principles Disciple",
  "description": "Evolutionary programming agent framework with strategic guardrails and reflection loops.",
  "version": "1.0.0",
  "author": "Principles Disciple Team",
  "skills": ["../../agents", "../../skills"],
  "configSchema": {
    "type": "object",
    "properties": {
      "auditLevel": {
        "type": "string",
        "enum": ["low", "medium", "high"],
        "default": "medium",
        "description": "The strictness of the gatekeeper."
      },
      "riskPaths": {
        "type": "array",
        "items": { "type": "string" },
        "default": ["src/", "infra/", "db/", ".claude/rules/"],
        "description": "Paths that require a READY plan before modification."
      },
      "gate": {
        "type": "object",
        "properties": {
          "requirePlanForRiskPaths": { "type": "boolean", "default": true },
          "requireAuditBeforeWrite": { "type": "boolean", "default": true }
        }
      },
      "tests": {
        "type": "object",
        "properties": {
          "onChange": { "type": "string", "default": "smoke" },
          "commands": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        }
      }
    }
  }
}

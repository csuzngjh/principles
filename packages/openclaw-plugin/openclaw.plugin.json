{
  "id": "principles-disciple",
  "name": "Principles Disciple",
  "description": "Evolutionary programming agent framework with strategic guardrails and reflection loops.",
  "version": "1.4.0",
  "skills": ["./agents", "./skills"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "language": {
        "type": "string",
        "enum": ["en", "zh"],
        "default": "en",
        "description": "The language for the generated templates and directives."
      },
      "auditLevel": {
        "type": "string",
        "enum": ["low", "medium", "high"],
        "default": "medium",
        "description": "The strictness of the gatekeeper."
      },
      "riskPaths": {
        "type": "array",
        "items": { "type": "string" },
        "default": ["src/", "infra/", "db/"],
        "description": "Paths that require a READY plan before modification."
      },
      "gate": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "requirePlanForRiskPaths": { "type": "boolean", "default": true },
          "requireAuditBeforeWrite": { "type": "boolean", "default": true }
        }
      },
      "tests": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "onChange": { "type": "string", "default": "smoke" },
          "commands": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        }
      }
    }
  },
  "uiHints": {
    "auditLevel": { "label": "Audit Level", "placeholder": "medium" },
    "riskPaths": { "label": "Risk Paths (require READY plan before write)" }
  }
}

#!/bin/bash
# Pre-push hook to prevent direct pushes to protected branches
# Installation: git init --template=~/.git-templates

# Check if we're in the principles workspace
cwd=$(pwd)
if [[ "$cwd" != *"principles"* ]]; then
  exit 0
fi

protected="master main"

while read local_ref local_sha remote_ref remote_sha; do
  remote_branch=$(echo "$remote_ref" | sed 's/refs\/heads\///')
  
  for branch in $protected; do
    if [ "$remote_branch" = "$branch" ]; then
      echo "⛔ 禁止直接推送到 $branch 分支"
      echo ""
      echo "请创建分支并通过 PR 合并:"
      echo "  git checkout -b fix/your-fix"
      echo "  # ... make changes ..."
      echo "  git push -u origin fix/your-fix"
      echo ""
      echo "或使用 GitHub CLI 创建 PR:"
      echo "  gh pr create --title 'Your title' --body 'Description'"
      exit 1
    fi
  done
done

exit 0
{
  "name": "principles-disciple-monorepo",
  "version": "1.10.37",
  "description": "Principles Disciple - OpenClaw Plugin Monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=@principles/core && npm run build --workspace=principles-disciple",
    "lint": "npm run build --workspace=@principles/core && npx eslint packages/**/*.ts --ignore-pattern **/*.test.ts --ignore-pattern **/*.spec.ts",
    "lint:fix": "npm run build --workspace=@principles/core && npx eslint packages/**/*.ts --ignore-pattern **/*.test.ts --ignore-pattern **/*.spec.ts --fix",
    "pre-commit": "lint-staged",
    "ai-sprint": "node packages/openclaw-plugin/templates/langs/zh/skills/ai-sprint-orchestration/scripts/run.mjs",
    "ai-sprint:test": "node --test packages/openclaw-plugin/templates/langs/zh/skills/ai-sprint-orchestration/test/*.mjs",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run",
    "version:patch": "cd packages/openclaw-plugin && npm version patch",
    "version:minor": "cd packages/openclaw-plugin && npm version minor",
    "version:major": "cd packages/openclaw-plugin && npm version major"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "eslint"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "lefthook": "^2.1.5",
    "lint-staged": "^16.4.0",
    "semantic-release": "^25.0.3"
  },
  "dependencies": {
    "glob": "^13.0.6"
  }
}
